name = "majornavi-auth"
main = "worker.js"
compatibility_date = "2026-03-17"

[vars]
SMS_PROVIDER = "aliyun"
SESSION_SECRET = "replace-with-a-long-random-string"
ALIYUN_SMS_SIGN_NAME = "REPLACE_WITH_GIFT_SIGN_NAME"
ALIYUN_SMS_TEMPLATE_CODE = "REPLACE_WITH_TEMPLATE_CODE"
ALIYUN_SMS_SCHEME_NAME = "majornavi"
ALIYUN_SMS_VALID_TIME = "300"
ALIYUN_SMS_INTERVAL = "60"
ALIYUN_SMS_CODE_LENGTH = "6"
ALIYUN_SMS_CODE_TYPE = "1"
ALIYUN_SMS_DUPLICATE_POLICY = "1"
ALIYUN_SMS_TEMPLATE_CODE_KEY = "code"
ALIYUN_SMS_TEMPLATE_MIN_KEY = "min"
